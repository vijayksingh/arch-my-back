# Convex Configuration
# Get your deployment URL from https://dashboard.convex.dev or by running `npx convex dev`
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Google OAuth Configuration (Optional - only needed if using Google sign-in)
# Follow the setup instructions in convex/auth.ts to get these values
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
